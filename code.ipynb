# ==========================================
# 4. MAIN: EXTRACT → CLEAN → SEND
# ==========================================

DELAY_SECONDS = 15  # ✅ 15 second gap between each email

extracted_data = extract_data_from_pdf(PDF_FILE_NAME)

if not extracted_data:
    print("⚠️  No data found. Update PDF_FILE_NAME with the correct full path and re-run.")
else:
    df = pd.DataFrame(extracted_data)
    initial_count = len(df)

    df['Email'] = df['Email'].str.strip().str.lower()
    df = df.drop_duplicates(subset=['Email'], keep='first')
    df = df[df['Email'].str.contains('@')]
    final_count = len(df)

    print(f"📊 Total: {initial_count} | Duplicates removed: {initial_count - final_count} | Sending to: {final_count}")
    print(f"⏱️  Delay between emails: {DELAY_SECONDS} seconds")

    estimated_minutes = round((final_count * DELAY_SECONDS) / 60, 1)
    print(f"🕐 Estimated total time: ~{estimated_minutes} minutes\n")

    server = None

    try:
        server = smtplib.SMTP_SSL("smtp.gmail.com", 465)
        server.login(SENDER_EMAIL, APP_PASSWORD)
        print("🔐 Gmail login successful! Sending emails...\n")

        success_count = 0
        fail_count    = 0

        for index, row in df.iterrows():
            name            = str(row['Name']).strip()
            recipient_email = str(row['Email']).strip()

            try:
                msg = MIMEMultipart()
                msg['From']    = SENDER_EMAIL
                msg['To']      = recipient_email
                msg['Subject'] = "Hiring for Data Analyst Internship – Analytics Career Connect"
                msg.attach(MIMEText(get_email_body(name), 'html'))

                server.send_message(msg)
                print(f"✅ [{success_count + fail_count + 1}/{final_count}] Sent → {name} ({recipient_email})")
                success_count += 1

            except Exception as e:
                print(f"❌ [{success_count + fail_count + 1}/{final_count}] Failed → {name} ({recipient_email}): {e}")
                fail_count += 1

            # ✅ 15 second wait — skip delay after last email
            if index != df.index[-1]:
                print(f"   ⏳ Waiting {DELAY_SECONDS} seconds before next email...")
                time.sleep(DELAY_SECONDS)

        print(f"\n🎉 Done! ✅ Sent: {success_count} | ❌ Failed: {fail_count}")

    except smtplib.SMTPAuthenticationError:
        print("❌ Login failed! Use an App Password, not your Gmail password.")
        print("   👉 Generate at: myaccount.google.com → Security → App Passwords")

    except Exception as e:
        print(f"❌ Unexpected error: {e}")

    finally:
        if server:
            try:
                server.quit()
            except:
                pass
