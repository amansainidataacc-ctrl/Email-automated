data = extract_data_from_pdf(PDF_FILE_NAME)

if not data:
    print("⚠️  No valid data found. Check your PDF and re-run.")
else:
    df = pd.DataFrame(data)
    df['Email'] = df['Email'].str.strip().str.lower()
    df = df.drop_duplicates(subset=['Email'], keep='first')
    total = len(df)

    server = None
    try:
        server = smtplib.SMTP_SSL("smtp.gmail.com", 465)
        server.login(SENDER_EMAIL, APP_PASSWORD)
        print("🔐 Login successful! Sending emails...\n")

        sent   = 0
        failed = 0

        for index, row in df.iterrows():
            name  = str(row['Name']).strip()
            email = str(row['Email']).strip()

            try:
                msg = MIMEMultipart()
                msg['From']    = SENDER_EMAIL
                msg['To']      = email
                msg['Subject'] = "Hiring for Data Analyst Internship – Analytics Career Connect"
                msg.attach(MIMEText(get_email_body(name), 'html'))

                server.send_message(msg)
                print(f"✅ [{sent + failed + 1}/{total}] Sent → {name} ({email})")
                sent += 1

            except Exception as e:
                print(f"❌ [{sent + failed + 1}/{total}] Failed → {name} ({email}): {e}")
                failed += 1

            if index != df.index[-1]:
                print(f"   ⏳ Waiting {DELAY_SECONDS} seconds...")
                time.sleep(DELAY_SECONDS)

        print(f"\n🎉 Done! ✅ Sent: {sent} | ❌ Failed: {failed}")

    except smtplib.SMTPAuthenticationError:
        print("❌ Login failed! Check your App Password.")
        print("   👉 myaccount.google.com → Security → App Passwords")

    except Exception as e:
        print(f"❌ Unexpected error: {e}")

    finally:
        if server:
            try:
                server.quit()
            except:
                pass
